{
  "programs.git.enable": {
    "declarations": ["/source/nixos/modules/programs/git.nix"],
    "description": "Whether to enable Git.",
    "type": "boolean",
    "default": {
      "_type": "literalExpression",
      "text": "false"
    },
    "example": true,
    "loc": ["programs", "git", "enable"],
    "visible": true
  },
  "programs.git.package": {
    "declarations": ["/source/nixos/modules/programs/git.nix"],
    "description": "Git package to use.",
    "type": "package",
    "default": {
      "_type": "literalExpression",
      "text": "pkgs.git"
    },
    "example": {
      "_type": "literalExpression",
      "text": "pkgs.gitFull"
    },
    "loc": ["programs", "git", "package"],
    "visible": true
  },
  "services.nginx.enable": {
    "declarations": [
      "/source/nixos/modules/services/web-servers/nginx/default.nix"
    ],
    "description": "Whether to enable the Nginx web server.",
    "type": "boolean",
    "default": {
      "_type": "literalExpression",
      "text": "false"
    },
    "example": true,
    "loc": ["services", "nginx", "enable"],
    "visible": true
  },
  "boot.loader.systemd-boot.enable": {
    "declarations": [
      "/source/nixos/modules/system/boot/loader/systemd-boot/systemd-boot.nix"
    ],
    "description": "Whether to enable the systemd-boot EFI boot manager.",
    "type": "boolean",
    "default": {
      "_type": "literalExpression",
      "text": "false"
    },
    "example": true,
    "loc": ["boot", "loader", "systemd-boot", "enable"],
    "visible": true
  }
}
